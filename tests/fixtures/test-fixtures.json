  "testScenarioMatrix": {
    "happy_path": [
      "Add objective → Objective displays on dashboard",
      "Edit objective → Changes persist in database",
      "Submit workout → AI context includes objective",
      "AI response → New training state created",
      "Multiple sessions → Training state evolves"
    ],
    "edge_cases": [
      "Empty/whitespace objective → Validation error",
      "Objective >500 chars → Truncated or rejected",
      "Special chars in objective → Sanitized correctly",
      "Edit with no changes → Idempotent behavior",
      "No objective existing → Fallback AI behavior"
    ],
    "security": [
      "User A cannot see User B's objective (403)",
      "Unauthorized request → 401 Unauthorized",
      "XSS attempt in objective → Sanitized",
      "Rate limiting on CRUD → 429 after X requests"
    ],
    "integration": [
      "Dashboard aggregation includes objective + state",
      "Cache invalidated on objective update",
      "Cache key includes objective hash"
    ]
  },

  "localTestCommands": {
    "seedData": "PGPASSWORD=password psql -h localhost -U postgres -d fawredd_gym -f tests/fixtures/seed.sql",
    "runAllPhase3BDD": "pnpm run test:bdd:ph3",
    "runSpecificScenario": "cucumber-js .agents/artifacts/tests/PH3-OBJECTIVE-TRAINING-tests.feature --name 'User successfully adds objective'",
    "runWithTag": "cucumber-js .agents/artifacts/tests/PH3-OBJECTIVE-TRAINING-tests.feature --tags '@security'",
    "runParallel": "cucumber-js .agents/artifacts/tests/PH3-OBJECTIVE-TRAINING-tests.feature --parallel 3",
    "generateReport": "pnpm run test:report"
  },

