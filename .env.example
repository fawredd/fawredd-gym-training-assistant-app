# Copy this file to .env.local and replace placeholder values with real secrets.
# Example: cp .env.example .env.local

# ------------------------
# Database (Postgres)
# ------------------------
# Used by drizzle.config.ts and scripts/init-db.js
# Example POSTGRES_URL format: postgres://user:password@host:port/dbname
POSTGRES_DB=fawredd_gym
POSTGRES_USER=fawredd
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Primary connection string consumed by Drizzle / scripts
# IMPORTANT: include the `schema` query parameter so Drizzle and deployment targets use the correct DB schema
# Example: postgresql://user:pass@host:5432/dbname?schema=fawredd_gym
POSTGRES_URL=postgresql://fawredd:change_me@localhost:5432/fawredd_gym?schema=db-schema-name

# Optional alternate env sometimes used by tools. Ensure it includes the `schema` param when required.
DATABASE_URL=postgresql://fawredd:change_me@localhost:5432/fawredd_gym?schema=db-schema-name

# Application DB schema (used in scripts or migrations)
APP_DB_SCHEMA=db-schema-name

# ------------------------
# Redis / Cache (Vercel Redis, Upstash, or local Redis)
# ------------------------
# If using a hosted Redis (Upstash/Vercel), set the URL. For local Docker Compose, you can set host/port/password.
REDIS_URL=redis://default:change_me@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# Optional specific provider keys
# For Vercel Redis integration you may have a connection string like VERCEL_REDIS_URL
VERCEL_REDIS_URL=redis://default:change_me@redis-host:6379

# ------------------------
# Clerk (Authentication)
# ------------------------
# Register an app at https://clerk.com and set the values below for local dev.
# Typically you will need a publishable frontend key (NEXT_PUBLIC_*) and a secret server key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk_publishable_key_placeholder
CLERK_SECRET_KEY=clerk_secret_key_placeholder

# ------------------------
# OpenRouter / AI provider
# ------------------------
# Used by AI endpoints (server-side). Keep this secret.
OPENROUTER_API_KEY=your_openrouter_api_key_here

GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# ------------------------
# Optional / Runtime
# ------------------------
# Base URL for local development (used by external callbacks or absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node / Next
NODE_ENV=development

#GOOGLE SITE VERIFICATION
GOOGLE_SITE_VERIFICATION=your_code

#PWA
# Use `npx web-push generate-vapid-keys` to generate these
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here

# Notes:
# - Never commit real secrets; copy this file to .env.local and populate values.
# - In Docker compose this repository also reads POSTGRES_DB/POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_PORT.
# - If deploying to Vercel, set environment variables in the project settings rather than committing a file.